---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Three tiers packaged around OUTCOMES, not deliverables, and no pricing — the
// conversation sets scope. Single CTA per the brief.
const tiers = [
  {
    name: 'Embedded',
    forWho: 'For a single race, expedition, or athlete moment.',
    outcome:
      'One unrepeatable effort, captured from the inside and turned into a film people actually finish watching.',
    includes: [
      'Embedded capture from inside the race or climb',
      'One hero film, festival- and sponsor-ready',
      'A set of vertical cutdowns for social',
      'Graded stills for press and partnerships',
    ],
  },
  {
    name: 'Campaign',
    forWho: 'For a product launch or brand story with a goal attached.',
    outcome:
      'A coordinated body of content built to move a number — entries, sell-through, sign-ups — not just to look good.',
    includes: [
      'Positioning and creative built around your outcome',
      'Multi-day production across locations',
      'Hero film + full social ecosystem in every ratio',
      'Sponsor- or channel-specific edits',
    ],
    featured: true,
  },
  {
    name: 'Retainer',
    forWho: 'For brands and races that need a season of content.',
    outcome:
      'A consistent visual voice across your whole season, from one filmmaker who already knows the sport and your audience.',
    includes: [
      'A planned slate of shoots across the season',
      'Priority booking around your race calendar',
      'A growing library of films, clips, and stills',
      'One point of contact who runs the races too',
    ],
  },
];
---

<BaseLayout
  title="Services"
  description="Three ways to work together — Embedded, Campaign, and Retainer — each packaged around the outcome you need, not a list of deliverables."
>
  <!-- Lead — LIGHT. -->
  <section class="container-rail pt-32 pb-12 md:pt-40 md:pb-16">
    <div class="max-w-3xl" data-reveal>
      <p class="eyebrow mb-4">Services</p>
      <h1
        class="font-display text-5xl font-medium leading-[0.95] tracking-tight md:text-7xl"
      >
        Outcomes, not packages of footage.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-dim">
        Three ways in, depending on how much you need and how often. No price
        list — scope and budget come out of a short conversation about what
        you’re trying to move.
      </p>
    </div>
  </section>

  <!-- Tiers — LIGHT cards. -->
  <section class="container-rail pb-20 md:pb-28">
    <div class="grid gap-6 lg:grid-cols-3">
      {
        tiers.map((tier) => (
          <div
            data-reveal
            class:list={[
              'flex flex-col rounded-xl p-7 md:p-8',
              tier.featured
                ? 'bg-ink text-bone'
                : 'bg-bone-raise ring-1 ring-line',
            ]}
          >
            <div class="flex items-center justify-between gap-3">
              <h2
                class:list={[
                  'text-2xl font-medium tracking-tight',
                  tier.featured ? 'text-bone' : 'text-ink',
                ]}
              >
                {tier.name}
              </h2>
              {tier.featured && (
                <span class="rounded-full border border-bone/40 px-3 py-1 text-[0.7rem] font-medium uppercase tracking-wider text-bone">
                  Most booked
                </span>
              )}
            </div>

            <p
              class:list={[
                'mt-2 text-sm font-medium',
                tier.featured ? 'text-bone-dim' : 'text-ink-faint',
              ]}
            >
              {tier.forWho}
            </p>

            <p
              class:list={[
                'mt-5 text-lg leading-relaxed',
                tier.featured ? 'text-bone-dim' : 'text-ink-dim',
              ]}
            >
              {tier.outcome}
            </p>

            <ul class="mt-7 space-y-3">
              {tier.includes.map((item) => (
                <li
                  class:list={[
                    'flex gap-3 text-sm leading-relaxed',
                    tier.featured ? 'text-bone-dim' : 'text-ink-dim',
                  ]}
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    aria-hidden="true"
                    class:list={[
                      'mt-0.5 shrink-0',
                      tier.featured ? 'text-bone' : 'text-ink',
                    ]}
                  >
                    <path d="M4 10.5l3.5 3.5L16 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <a
              href="/contact"
              class:list={[
                'mt-8 w-full justify-center',
                tier.featured ? 'btn-bone' : 'btn-ghost',
              ]}
            >
              Start a conversation
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Reassurance / how it works pointer — LIGHT. -->
  <section class="border-t border-line bg-bone-raise/60">
    <div class="container-rail py-16 md:py-20">
      <div class="grid items-center gap-8 md:grid-cols-[1.4fr_1fr]" data-reveal>
        <div>
          <h2 class="text-2xl font-medium tracking-tight md:text-3xl">
            Not sure which fits?
          </h2>
          <p class="mt-3 max-w-xl text-lg leading-relaxed text-ink-dim">
            Tell me the outcome you’re after and I’ll tell you honestly whether
            it’s a single film or a season. I only take on a handful of projects
            at a time, so every one gets the legs it deserves.
          </p>
        </div>
        <div class="flex md:justify-end">
          <a href="/contact" class="btn-ink">
            Get in touch
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
