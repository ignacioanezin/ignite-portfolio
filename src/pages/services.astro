---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Full page lands in a later build step. Stub keeps nav from 404-ing.
---

<BaseLayout title="Services">
  <section class="container-rail flex min-h-[60vh] flex-col justify-center py-32">
    <p class="eyebrow mb-4">Services</p>
    <h1 class="text-4xl font-semibold md:text-6xl">Coming together next.</h1>
    <p class="mt-4 max-w-md text-ink-dim">
      This page is being built. Back to the
      <a href="/" class="link-underline text-ink">home page</a>.
    </p>
  </section>
</BaseLayout>
