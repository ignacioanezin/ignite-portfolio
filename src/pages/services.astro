---
import BaseLayout from '@/layouts/BaseLayout.astro';
import T from '@/components/T.astro';
import { ui } from '@/i18n/ui';

const tiers = [
  { id: 'embedded', featured: false },
  { id: 'campaign', featured: true },
  { id: 'retainer', featured: false },
];
---

<BaseLayout
  title="Services"
  titleEs="Servicios"
  description={ui.en['services.meta_desc']}
  descriptionEs={ui.es['services.meta_desc']}
>
  <!-- Lead. -->
  <section class="container-rail pt-32 pb-12 md:pt-40 md:pb-16">
    <div class="max-w-4xl" data-reveal>
      <p class="eyebrow eyebrow-tick mb-5"><T k="services.eyebrow" /></p>
      <h1
        class="font-display text-5xl font-bold uppercase leading-[0.9] tracking-tight md:text-8xl"
      >
        <T k="services.h1" />
      </h1>
      <p class="mt-7 max-w-xl text-lg font-medium leading-relaxed text-ink-dim">
        <T k="services.intro" />
      </p>
    </div>
  </section>

  <!-- Tiers. Featured = inverted ink card (emphasis by colour, not height). -->
  <section class="container-rail pb-20 md:pb-28">
    <div class="grid gap-6 lg:grid-cols-3" data-reveal-group>
      {
        tiers.map((tier) => (
          <div
            data-reveal
            class:list={[
              'flex flex-col border-2 border-ink p-7 md:p-8',
              tier.featured ? 'bg-ink text-paper' : 'bg-paper-bright',
            ]}
          >
            <div class="flex items-center justify-between gap-3">
              <h2 class="text-2xl font-bold uppercase tracking-tight">
                <T k={`svc.${tier.id}.name`} />
              </h2>
              {tier.featured && (
                <span class="mono-label rounded-full bg-flare px-2.5 py-1 text-paper">
                  <T k="services.most_booked" />
                </span>
              )}
            </div>

            <p
              class:list={[
                'mono-label mt-3',
                tier.featured ? 'text-paper/60' : 'text-ink-faint',
              ]}
            >
              <T k={`svc.${tier.id}.for`} />
            </p>

            <p
              class:list={[
                'mt-5 text-lg leading-relaxed',
                tier.featured ? 'text-paper/85' : 'text-ink-dim',
              ]}
            >
              <T k={`svc.${tier.id}.outcome`} />
            </p>

            <ul class="mt-7 space-y-3">
              {[1, 2, 3, 4].map((n) => (
                <li
                  class:list={[
                    'flex gap-3 text-sm leading-relaxed',
                    tier.featured ? 'text-paper/85' : 'text-ink-dim',
                  ]}
                >
                  <svg
                    width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                    stroke-width="2.2" aria-hidden="true" class="mt-0.5 shrink-0 text-flare"
                  >
                    <path d="M4 10.5l3.5 3.5L16 6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <span><T k={`svc.${tier.id}.i${n}`} /></span>
                </li>
              ))}
            </ul>

            <a
              href="/contact"
              class:list={[
                'mt-8 w-full justify-center',
                tier.featured ? 'btn-paper' : 'btn-ink',
              ]}
            >
              <T k="services.tier_cta" />
            </a>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Reassurance. -->
  <section class="border-t-2 border-ink">
    <div class="container-rail py-16 md:py-20">
      <div class="grid items-center gap-8 md:grid-cols-[1.4fr_1fr]" data-reveal>
        <div>
          <h2 class="text-3xl font-bold uppercase leading-[0.95] tracking-tight md:text-4xl">
            <T k="services.reassure_h2" />
          </h2>
          <p class="mt-3 max-w-xl text-lg leading-relaxed text-ink-dim">
            <T k="services.reassure_body" />
          </p>
        </div>
        <div class="flex md:justify-end">
          <a href="/contact" class="btn-ink" data-magnetic>
            <T k="services.reassure_cta" />
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
