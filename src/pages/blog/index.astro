---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import T from '@/components/T.astro';
import { ui } from '@/i18n/ui';

// Blog index. Newest first; drafts excluded from the build.
const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = (d: Date, locale: string) =>
  d.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Blog"
  titleEs="Blog"
  description={ui.en['blog.meta_desc']}
  descriptionEs={ui.es['blog.meta_desc']}
>
  <section class="container-rail pt-32 pb-20 md:pt-40 md:pb-28">
    <!-- Header -->
    <div class="flex flex-wrap items-end justify-between gap-6" data-reveal>
      <div class="max-w-4xl">
        <p class="eyebrow eyebrow-tick mb-5"><T k="blog.eyebrow" /></p>
        <h1
          class="font-display text-5xl font-bold uppercase leading-[0.9] tracking-tight md:text-8xl"
        >
          <T k="blog.h1" />
        </h1>
        <p class="mt-7 max-w-xl text-lg font-medium leading-relaxed text-ink-dim">
          <T k="blog.intro" />
        </p>
      </div>
      <a
        href="/rss.xml"
        class="group mono-label inline-flex items-center gap-2 text-flare transition-opacity hover:opacity-70"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M2 11a3 3 0 0 1 3 3H2v-3zm0-4a7 7 0 0 1 7 7H7A5 5 0 0 0 2 9V7zm0-4a11 11 0 0 1 11 11h-2A9 9 0 0 0 2 5V3z"></path>
        </svg>
        RSS
      </a>
    </div>

    <!-- List -->
    {
      posts.length === 0 ? (
        <p class="mt-16 text-ink-dim" data-reveal>
          <T k="blog.empty" />
        </p>
      ) : (
        <ul class="mt-14 border-t-2 border-ink" data-reveal-group>
          {posts.map((post) => (
            <li data-reveal class="border-b-2 border-ink">
              <a
                href={`/blog/${post.id}`}
                class="group grid gap-5 py-8 md:grid-cols-[1fr_2fr] md:gap-10 md:py-10"
              >
                {post.data.heroImage ? (
                  <div class="aspect-[16/10] overflow-hidden border-2 border-ink bg-paper-bright">
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.title}
                      widths={[320, 640]}
                      sizes="(min-width: 768px) 33vw, 100vw"
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                  </div>
                ) : (
                  <div class="hidden md:block" />
                )}

                <div class="md:py-1">
                  <p class="mono-label tnum text-flare">
                    <time datetime={post.data.pubDate.toISOString()}>
                      <T
                        en={dateFmt(post.data.pubDate, 'en-US')}
                        es={dateFmt(post.data.pubDate, 'es-AR')}
                      />
                    </time>
                  </p>
                  <h2 class="mt-3 font-display text-2xl font-bold tracking-tight underline-offset-[6px] decoration-2 group-hover:underline md:text-4xl">
                    <T
                      en={post.data.title}
                      es={post.data.title_es ?? post.data.title}
                    />
                  </h2>
                  <p class="mt-3 max-w-2xl leading-relaxed text-ink-dim">
                    <T
                      en={post.data.description}
                      es={post.data.description_es ?? post.data.description}
                    />
                  </p>
                  {post.data.tags.length > 0 && (
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <li class="mono-label rounded-full border-2 border-ink px-3 py-1 text-ink">
                          {tag}
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
