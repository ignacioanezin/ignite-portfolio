---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { heroIsReel } from '@/lib/site';
import Hero from '@/components/home/Hero.astro';
import MetricsStrip from '@/components/home/MetricsStrip.astro';
import ClientsWall from '@/components/home/ClientsWall.astro';
import FeaturedWork from '@/components/home/FeaturedWork.astro';
import Process from '@/components/home/Process.astro';
import BlogTeaser from '@/components/home/BlogTeaser.astro';
import CtaSection from '@/components/home/CtaSection.astro';
import Marquee from '@/components/Marquee.astro';

const credits = [
  'DIRECTOR',
  'DP',
  'EDITOR',
  'COLOR',
  'ONE PRODUCTION → A SEASON OF CONTENT',
];
---

<BaseLayout darkChrome={heroIsReel}>
  {/* hero → proof (metrics + clients) → featured work → process → blog → CTA */}
  <Hero />
  <MetricsStrip />
  <ClientsWall />
  <FeaturedWork />
  <Marquee items={credits} variant="ink" speed={34} reverse />
  <Process />
  <BlogTeaser />
  <CtaSection />
</BaseLayout>
