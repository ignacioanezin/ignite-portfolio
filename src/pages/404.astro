---
import BaseLayout from '@/layouts/BaseLayout.astro';
import T from '@/components/T.astro';
---

<BaseLayout title="Page not found" titleEs="Página no encontrada" noindex>
  <section
    class="container-rail flex min-h-[70vh] flex-col justify-center py-32"
  >
    <p class="eyebrow mb-4">404</p>
    <h1
      class="font-display text-5xl font-medium leading-[0.95] tracking-tight md:text-7xl"
    >
      <T k="404.h1" />
    </h1>
    <p class="mt-6 max-w-md text-lg leading-relaxed text-ink-dim">
      <T k="404.body" />
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-4">
      <a href="/" class="btn-ink">
        <T k="404.home" />
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <a href="/work" class="btn-ghost"><T k="404.work" /></a>
    </div>
  </section>
</BaseLayout>
