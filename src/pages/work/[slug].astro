---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import YouTubeFacade from '@/components/YouTubeFacade.astro';
import StillsSlider from '@/components/StillsSlider.astro';
import T from '@/components/T.astro';
import { SITE } from '@/lib/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

const { Content } = await render(project);

// Case-study spine, in brief order. Result only when present (honesty).
const sections = [
  { key: 'cs.challenge', en: data.challenge, es: data.challenge_es ?? data.challenge },
  { key: 'cs.strategy', en: data.strategy, es: data.strategy_es ?? data.strategy },
  { key: 'cs.production', en: data.production, es: data.production_es ?? data.production },
  ...(data.result
    ? [{ key: 'cs.result', en: data.result, es: data.result_es ?? data.result }]
    : []),
];

const deliverables = data.deliverables.map((d, i) => ({
  en: d,
  es: data.deliverables_es?.[i] ?? d,
}));

// "Splits" — production data strip. Only populated fields render (honesty).
// `accent` flags the numeric/timecode values rendered in flare.
const splits = [
  { label: 'Role', value: data.role },
  { label: 'Year', value: String(data.year), accent: true },
  { label: 'Location', value: data.location },
  ...(data.client ? [{ label: 'Client', value: data.client }] : []),
  ...(data.tcIn ? [{ label: 'TC In', value: data.tcIn, accent: true }] : []),
  ...(data.tcOut ? [{ label: 'TC Out', value: data.tcOut, accent: true }] : []),
  ...(data.lens ? [{ label: 'Lens', value: data.lens }] : []),
  ...(data.elevationGain
    ? [{ label: 'D+ Vert', value: data.elevationGain, accent: true }]
    : []),
] as { label: string; value: string; accent?: boolean }[];

const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: data.title,
  description: data.excerpt,
  thumbnailUrl: new URL(data.thumbnail.src, SITE.url).href,
  uploadDate: `${data.year}-01-01`,
  embedUrl: `https://www.youtube-nocookie.com/embed/${data.youtubeId}`,
  creator: { '@type': 'Person', name: SITE.name },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Work', item: new URL('/work', SITE.url).href },
    {
      '@type': 'ListItem',
      position: 3,
      name: data.title,
      item: new URL(`/work/${project.id}`, SITE.url).href,
    },
  ],
};
---

<BaseLayout
  title={data.title}
  description={data.excerpt}
  descriptionEs={data.excerpt_es ?? data.excerpt}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <article>
    <!-- Header. -->
    <header class="container-rail pt-32 pb-10 md:pt-40 md:pb-14">
      <a
        href="/work"
        class="group mono-label inline-flex items-center gap-2 text-flare transition-opacity hover:opacity-70"
        data-reveal
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="transition-transform group-hover:-translate-x-1">
          <path d="M13 8H3M7 4L3 8l4 4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <T k="cs.back" />
      </a>

      <p class="eyebrow eyebrow-tick mt-8 mb-4" data-reveal><T k={`cat.${data.category}`} /></p>
      <h1
        class="max-w-5xl font-display text-5xl font-bold uppercase leading-[0.9] tracking-tight md:text-8xl"
        data-reveal
      >
        {data.title}
      </h1>
      <p class="mt-6 max-w-2xl text-xl font-medium leading-snug text-ink-dim" data-reveal>
        <T en={data.excerpt} es={data.excerpt_es ?? data.excerpt} />
      </p>
    </header>

    <!-- Video. -->
    <div class="container-rail" data-reveal>
      <YouTubeFacade
        youtubeId={data.youtubeId}
        title={data.title}
        poster={data.thumbnail}
      />
    </div>

    <!-- Splits — production data strip. -->
    <div class="container-rail mt-8 md:mt-10" data-reveal>
      <dl class="grid grid-cols-2 gap-x-6 gap-y-6 border-y-2 border-ink py-6 sm:grid-cols-4">
        {
          splits.map((s) => (
            <div>
              <dt class="mono-label text-ink-faint">{s.label}</dt>
              <dd
                class:list={[
                  'mono mt-1.5 text-base font-medium tracking-[0.02em]',
                  s.accent ? 'text-flare' : 'text-ink',
                ]}
              >
                {s.value}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <!-- Case-study spine. -->
    <div class="container-rail py-16 md:py-24">
      <div class="grid gap-x-16 gap-y-12 lg:grid-cols-[1fr_1.4fr]">
        <div class="lg:sticky lg:top-28 lg:self-start" data-reveal>
          <h2 class="text-3xl font-bold uppercase leading-[0.95] tracking-tight md:text-5xl">
            <T k="cs.spine_h2" />
          </h2>
        </div>

        <div class="space-y-12">
          {
            sections.map((s) => (
              <section data-reveal>
                <h3 class="eyebrow eyebrow-tick mb-3"><T k={s.key} /></h3>
                <p class="text-lg leading-relaxed text-ink-dim md:text-xl">
                  <T en={s.en} es={s.es} />
                </p>
              </section>
            ))
          }

          <section data-reveal>
            <h3 class="eyebrow eyebrow-tick mb-4"><T k="cs.ecosystem" /></h3>
            <ul class="space-y-3">
              {
                deliverables.map((d) => (
                  <li class="flex gap-3 text-lg leading-relaxed text-ink-dim">
                    <svg
                      width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor"
                      stroke-width="2.2" aria-hidden="true" class="mt-1 shrink-0 text-flare"
                    >
                      <path d="M4 10.5l3.5 3.5L16 6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span><T en={d.en} es={d.es} /></span>
                  </li>
                ))
              }
            </ul>
          </section>

          {
            data.tags && data.tags.length > 0 && (
              <ul class="flex flex-wrap gap-2" data-reveal>
                {data.tags.map((tag) => (
                  <li class="mono-label rounded-full border-2 border-ink px-3 py-1.5 text-ink">
                    {tag}
                  </li>
                ))}
              </ul>
            )
          }

          <div
            class="prose-note border-t-2 border-ink pt-8 text-lg italic leading-relaxed text-ink-dim"
            data-reveal
          >
            <Content />
          </div>
        </div>
      </div>
    </div>

    <!-- Optional vertical cutdowns (9:16) — the social deliverables. -->
    {
      data.verticals && data.verticals.length > 0 && (
        <div class="container-rail pb-12 md:pb-16">
          <p class="mono-label mb-5 text-ink-faint" data-reveal>
            <T k="cs.verticals" />
          </p>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4">
            {data.verticals.map((v) => (
              <figure data-reveal>
                <YouTubeFacade
                  youtubeId={v.youtubeId}
                  title={data.title}
                  poster={v.poster}
                  aspect="portrait"
                />
                {v.caption && (
                  <figcaption class="mono-label mt-2.5 text-ink-faint">
                    <T en={v.caption} es={v.caption_es ?? v.caption} />
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        </div>
      )
    }

    <!-- Optional stills — large horizontal reel (slider) so each frame reads big. -->
    {
      data.gallery && data.gallery.length > 0 && (
        <div class="container-rail pb-16 md:pb-24">
          <p class="mono-label mb-5 text-ink-faint" data-reveal>
            <T k="cs.stills" />
          </p>
          <StillsSlider images={data.gallery} title={data.title} />
        </div>
      )
    }

    <!-- CTA — flare colour-field close. -->
    <section class="bg-flare text-paper">
      <div class="container-rail py-20 md:py-28">
        <div class="mx-auto max-w-2xl text-center" data-reveal>
          <h2 class="text-4xl font-bold uppercase leading-[0.95] tracking-tight md:text-6xl">
            <T k="cs.cta_h2" />
          </h2>
          <p class="mx-auto mt-5 max-w-lg text-lg text-paper/90">
            <T k="cs.cta_body" />
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
            <a href="/contact" class="btn-paper" data-magnetic>
              <T k="cta.start" />
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
            <a href="/work" class="btn-ghost-paper"><T k="cs.more" /></a>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
