---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import WorkRow from '@/components/WorkRow.astro';
import WorkFilter from '@/components/react/WorkFilter.tsx';
import T from '@/components/T.astro';
import { CATEGORY_META, type CategoryKey } from '@/content.config';
import { ui } from '@/i18n/ui';

// Full curated start list. Newest first; equal hierarchy.
const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);

// Category tabs with live counts — only categories that actually have work
// appear (no empty filters). Order follows CATEGORY_META.
const counts = projects.reduce<Record<string, number>>((acc, p) => {
  acc[p.data.category] = (acc[p.data.category] ?? 0) + 1;
  return acc;
}, {});

const categories = (Object.keys(CATEGORY_META) as CategoryKey[])
  .filter((key) => counts[key])
  .sort((a, b) => CATEGORY_META[a].order - CATEGORY_META[b].order)
  .map((key) => ({
    key,
    en: ui.en[`cat.${key}`],
    es: ui.es[`cat.${key}`],
    count: counts[key],
  }));

const pad = (n: number) => String(n).padStart(2, '0');
---

<BaseLayout
  title="Work"
  titleEs="Trabajo"
  description={ui.en['work.meta_desc']}
  descriptionEs={ui.es['work.meta_desc']}
>
  <section class="container-rail pt-32 pb-20 md:pt-40 md:pb-28">
    <!-- Header -->
    <div class="max-w-4xl" data-reveal>
      <p class="eyebrow eyebrow-tick mb-5"><T k="work.eyebrow" /></p>
      <h1
        class="font-display text-5xl font-bold uppercase leading-[0.9] tracking-tight md:text-8xl"
      >
        <T k="work.h1" />
      </h1>
      <p class="mt-7 max-w-xl text-lg font-medium leading-relaxed text-ink-dim">
        <T k="work.intro" />
      </p>
    </div>

    <!-- Filter -->
    <div class="mt-12 md:mt-16" data-reveal>
      <WorkFilter
        categories={categories}
        total={projects.length}
        allEn={ui.en['filter.all']}
        allEs={ui.es['filter.all']}
        client:idle
      />
      <p id="work-filter-status" class="sr-only" role="status" aria-live="polite"></p>
    </div>

    <!-- Start list -->
    <div class="mt-10 md:mt-14" data-reveal-group>
      {
        projects.map((project, i) => (
          <div data-work-item data-category={project.data.category}>
            <WorkRow project={project} index={pad(i + 1)} priority={i < 2} />
          </div>
        ))
      }
      <div class="border-t-2 border-ink"></div>
    </div>
  </section>
</BaseLayout>
