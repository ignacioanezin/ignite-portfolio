---
import BaseLayout from '@/layouts/BaseLayout.astro';
// Full filterable grid lands in build step 5. Stub keeps nav from 404-ing.
---

<BaseLayout title="Work" description="Selected films for outdoor and trail-running brands, races, and athletes.">
  <section class="container-rail flex min-h-[60vh] flex-col justify-center py-32">
    <p class="eyebrow mb-4">Work</p>
    <h1 class="text-4xl font-semibold md:text-6xl">Coming together next.</h1>
    <p class="mt-4 max-w-md text-ink-dim">
      The filterable case-study grid is being built. For now, the featured
      projects live on the <a href="/" class="link-underline text-ink">home page</a>.
    </p>
  </section>
</BaseLayout>
