---
import { Image } from 'astro:assets';
import { CATEGORY_META } from '@/content.config';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/T.astro';

// Poster card — the footage is the protagonist. A large always-visible still
// fills the card; the bib index + title + meta sit overlaid on a dark scrim at
// the bottom. When a project has a `previewClip`, it cross-fades to a muted
// video loop on hover (desktop, motion-allowed); otherwise the still alone
// shows (honesty fallback). Used on the home "Featured work" grid and the Work
// page grid — replaced the text-first start-list row (WorkRow).

interface Props {
  project: CollectionEntry<'projects'>;
  /** Bib index, e.g. "01". */
  index: string;
  /** Eager-load the still (above-the-fold cards). */
  priority?: boolean;
  class?: string;
}

const { project, index, priority = false, class: className } = Astro.props;
const { data } = project;
const category = CATEGORY_META[data.category];

// "Splits" — optional production stats (honesty: only the ones that exist).
const splits = [data.lens, data.elevationGain].filter(Boolean) as string[];
---

<a
  href={`/work/${project.id}`}
  class:list={[
    'group relative block overflow-hidden bg-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-flare',
    className,
  ]}
  data-reveal
  aria-label={`${data.title} — ${category.label}`}
>
  <!-- Frame — large still (and optional hover video) at a constant 3:2. -->
  <div
    data-img-reveal
    data-hover-video={data.previewClip ? '' : undefined}
    class="relative aspect-[3/2] overflow-hidden bg-paper-bright"
  >
    <Image
      src={data.thumbnail}
      alt={`${data.title} — ${category.label}`}
      widths={[640, 960, 1280]}
      sizes="(min-width: 768px) 50vw, 100vw"
      loading={priority ? 'eager' : 'lazy'}
      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
    />

    {
      data.previewClip && (
        <video
          class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500 ease-out group-hover:opacity-100"
          src={data.previewClip}
          poster={data.thumbnail.src}
          muted
          loop
          playsinline
          preload="none"
          aria-hidden="true"
        />
      )
    }

    <!-- Scrim so the overlaid text stays legible over any frame. -->
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-transparent"
      aria-hidden="true"
    >
    </div>

    <!-- Overlay: bib + title + meta, anchored to the bottom. -->
    <div class="absolute inset-x-0 bottom-0 p-5 md:p-6">
      <span class="mono block text-sm font-medium text-flare md:text-base">{index}</span>
      <h3
        class="mt-1.5 font-display text-3xl font-bold uppercase leading-[0.95] tracking-tight text-paper sm:text-4xl md:text-5xl"
      >
        {data.title}
      </h3>
      <p class="mono-label mt-2.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-paper/75">
        <span class="text-paper"><T k={`cat.${data.category}`} /></span>
        {data.client && <><span aria-hidden="true">·</span><span>{data.client}</span></>}
        <span aria-hidden="true">·</span>
        <span class="tnum">{data.year}</span>
        {
          splits.map((s) => (
            <>
              <span aria-hidden="true" class="text-flare">/</span>
              <span class="tnum">{s}</span>
            </>
          ))
        }
      </p>
    </div>
  </div>
</a>
