---
import { getCollection } from 'astro:content';
import T from '@/components/T.astro';

// LIGHT — sits between Process (light) and the dark CTA close. Additive section
// in the existing style; pulls the 3 newest posts. Renders nothing when there
// are no posts (so it never shows an empty band).
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFmt = (d: Date, locale: string) =>
  d.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' });
---

{
  posts.length > 0 && (
    <section aria-label="From the Blog" class="border-t-2 border-ink">
      <div class="container-rail py-20 md:py-28">
        <div
          class="mb-12 flex flex-wrap items-end justify-between gap-6"
          data-reveal
        >
          <div>
            <p class="eyebrow eyebrow-tick mb-4">
              <T k="home.blog_eyebrow" />
            </p>
            <h2 class="max-w-2xl text-4xl font-bold uppercase leading-[0.95] tracking-tight md:text-6xl">
              <T k="home.blog_h2" />
            </h2>
          </div>
          <a
            href="/blog"
            class="group mono-label inline-flex items-center gap-2 text-flare transition-opacity hover:opacity-70"
          >
            <T k="home.blog_all" />
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              aria-hidden="true"
              class="transition-transform group-hover:translate-x-1"
            >
              <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <ul class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
          {posts.map((post) => (
            <li data-reveal class="border-t-2 border-ink pt-5">
              <a href={`/blog/${post.id}`} class="group block">
                <p class="mono-label tnum text-flare">
                  <time datetime={post.data.pubDate.toISOString()}>
                    <T
                      en={dateFmt(post.data.pubDate, 'en-US')}
                      es={dateFmt(post.data.pubDate, 'es-AR')}
                    />
                  </time>
                </p>
                <h3 class="mt-3 text-xl font-bold tracking-tight underline-offset-[6px] decoration-2 group-hover:underline">
                  <T
                    en={post.data.title}
                    es={post.data.title_es ?? post.data.title}
                  />
                </h3>
                <p class="mt-2.5 text-sm leading-relaxed text-ink-dim">
                  <T
                    en={post.data.description}
                    es={post.data.description_es ?? post.data.description}
                  />
                </p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}
