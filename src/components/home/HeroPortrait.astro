---
import { Image } from 'astro:assets';
import { SITE } from '@/lib/site';
import T from '@/components/T.astro';
import Marquee from '@/components/Marquee.astro';
import portrait from '@/assets/hero/ignacio.png';

// Kinetic sport hero (LIGHT). A wall of oversized UPPERCASE type, the B&W
// portrait full-height on the right, a flare CTA, and a flare manifesto marquee
// running across the bottom — the differentiator made physical motion.
const [first, last] = SITE.name.split(' ');

const manifestoEn = [
  'I RUN THE RACES I FILM',
  'EMBEDDED',
  'PATAGONIA',
  'THE ANDES',
  'ATHLETE—FILMMAKER',
];
const manifestoEs = [
  'CORRO LAS CARRERAS QUE FILMO',
  'DESDE ADENTRO',
  'PATAGONIA',
  'LOS ANDES',
  'ATLETA—CINEASTA',
];
---

<section
  class="relative flex min-h-[100svh] flex-col overflow-hidden"
  aria-label="Introduction"
>
  <!-- Subject — full-contrast B&W, bleeds off the bottom-right. -->
  <div
    class="pointer-events-none relative z-0 w-full h-[52vh] -mb-[4rem]
           sm:h-[56vh]
           md:absolute md:bottom-[4.75rem] md:left-auto md:right-[6%] md:h-[68vh] md:w-[44%] md:translate-x-0
           lg:right-[8%] lg:max-w-xl"
  >
    <Image
      src={portrait}
      alt={`${SITE.name}, athlete-filmmaker`}
      widths={[480, 768, 1100]}
      sizes="(min-width: 768px) 52vw, 100vw"
      loading="eager"
      fetchpriority="high"
      class="h-full w-auto max-w-none object-contain object-bottom"
    />
  </div>

  <!-- Legibility wash on the type side. -->
  <div
    class="pointer-events-none absolute inset-0 z-[1] hidden bg-gradient-to-r from-paper from-30% via-paper/80 to-transparent to-70% md:block"
    aria-hidden="true"
  >
  </div>

  <!-- Type wall. -->
  <div
    class="container-rail relative z-10 flex flex-1 flex-col justify-center pt-24 pb-4 md:pt-0 md:pb-44"
  >
    <div data-reveal-group>
      <p class="eyebrow eyebrow-tick mb-6" data-reveal>
        <T en="Embedded athlete-filmmaker" es="Atleta y cineasta, desde adentro" />
      </p>

      <h1
        class="font-display font-bold uppercase text-ink"
        style="font-size: var(--text-mega); line-height: var(--text-mega--line-height); letter-spacing: var(--text-mega--letter-spacing);"
        data-reveal="rise"
      >
        <span class="rise-mask">
          <span class="block">{first}</span>
          <span class="block">{last}</span>
        </span>
      </h1>

      <p
        class="mt-7 max-w-xl text-balance text-xl font-medium leading-snug text-ink-dim md:text-2xl"
        data-reveal
      >
        <T k="site.statement" />
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-4" data-reveal>
        <a href="/work" class="btn-ink" data-magnetic>
          <T k="hero.cta_work" />
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href="/contact" class="btn-ghost" data-magnetic><T k="hero.cta_contact" /></a>
      </div>
    </div>
  </div>

  <!-- Manifesto marquee — the kinetic signature. -->
  <div class="absolute inset-x-0 bottom-0 z-10">
    <div data-lang="en">
      <Marquee items={manifestoEn} variant="flare" speed={26} />
    </div>
    <div data-lang="es">
      <Marquee items={manifestoEs} variant="flare" speed={26} />
    </div>
  </div>
</section>
