---
import { getCollection } from 'astro:content';
import WorkPoster from '@/components/WorkPoster.astro';
import T from '@/components/T.astro';

const featured = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 4);

const pad = (n: number) => String(n).padStart(2, '0');
---

<!-- Selected work as a bold poster grid — the footage leads. -->
<section aria-label="Selected work">
  <div class="container-rail py-20 md:py-28">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-6" data-reveal>
      <div>
        <p class="eyebrow eyebrow-tick mb-4"><T k="featured.eyebrow" /></p>
        <h2 class="max-w-3xl text-4xl font-bold uppercase leading-[0.95] tracking-tight md:text-6xl">
          <T k="featured.h2" />
        </h2>
      </div>
      <a
        href="/work"
        class="group mono-label inline-flex items-center gap-2 text-flare transition-opacity hover:opacity-70"
      >
        <T k="featured.all" />
        <svg
          width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"
          aria-hidden="true" class="transition-transform group-hover:translate-x-1"
        >
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:gap-8"
      data-reveal-group
    >
      {featured.map((project, i) => (
        <WorkPoster project={project} index={pad(i + 1)} priority={i < 2} />
      ))}
    </div>
  </div>
</section>
