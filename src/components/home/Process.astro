---
import T from '@/components/T.astro';

// How an engagement works — framed as a partner, not a camera-for-hire. Copy
// lives in the i18n dictionary (process.*); we just map the step keys here.
const steps = [
  { n: '01', key: 's1' },
  { n: '02', key: 's2' },
  { n: '03', key: 's3' },
  { n: '04', key: 's4' },
];
---

<section
  aria-label="How we work together"
  class="border-t border-line bg-bone-raise/60"
>
  <div class="container-rail py-20 md:py-28">
    <div class="mb-14 max-w-2xl" data-reveal>
      <p class="eyebrow mb-3"><T k="process.eyebrow" /></p>
      <h2 class="text-4xl font-semibold md:text-5xl">
        <T k="process.h2" />
      </h2>
    </div>

    <ol class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
      {
        steps.map((step) => (
          <li data-reveal class="border-t border-line pt-5">
            <span class="font-display text-3xl font-medium tracking-tight text-ink-faint">
              {step.n}
            </span>
            <h3 class="mt-4 text-xl font-medium">
              <T k={`process.${step.key}.title`} />
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-dim">
              <T k={`process.${step.key}.body`} />
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
