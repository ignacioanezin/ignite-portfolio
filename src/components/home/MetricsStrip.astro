---
import { METRICS, hasMetrics } from '@/data/metrics';
// Renders nothing unless there are real metrics — never invented / zero values.
---

{
  hasMetrics && (
    <section aria-label="Proof in numbers" class="border-y-2 border-ink">
      <div class="container-rail py-14 md:py-20">
        <dl
          class="grid grid-cols-2 gap-x-8 gap-y-12 md:grid-cols-4"
          data-reveal
        >
          {METRICS.map((m) => (
            <div>
              <dt class="sr-only">{m.label}</dt>
              <dd>
                <span class="mono tnum block text-5xl font-bold tracking-tight text-flare md:text-7xl">
                  {m.value}
                </span>
                <span class="mono-label mt-2 block text-ink-faint">{m.label}</span>
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )
}
