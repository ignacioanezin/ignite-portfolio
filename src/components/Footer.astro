---
import { SITE, NAV_LINKS } from '@/lib/site';
import T from '@/components/T.astro';
const year = new Date().getFullYear();
---

<!-- Bold ink field — closes the page hard after the flare CTA. -->
<footer class="bg-ink text-paper">
  <div class="container-rail py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr]">
      <!-- Brand + pitch -->
      <div>
        <p class="font-display text-3xl font-bold uppercase tracking-tight md:text-4xl">
          {SITE.name}
        </p>
        <p class="mt-4 max-w-xs leading-relaxed text-paper/70">
          <T k="site.statement" />
        </p>
        <p class="mono-label mt-5 text-paper/50">
          {SITE.baseLocation} · {SITE.shootingRegion}
        </p>
      </div>

      <!-- Nav -->
      <nav aria-label="Footer">
        <p class="mono-label mb-4 text-flare"><T k="footer.site" /></p>
        <ul class="space-y-2.5">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="link-underline text-paper/80 transition-colors hover:text-paper"
                >
                  <T k={link.key} />
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="/blog"
              class="link-underline text-paper/80 transition-colors hover:text-paper"
            >
              <T k="nav.blog" />
            </a>
          </li>
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <p class="mono-label mb-4 text-flare"><T k="footer.getintouch" /></p>
        <ul class="space-y-2.5">
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="link-underline text-paper/80 transition-colors hover:text-paper"
            >
              {SITE.email}
            </a>
          </li>
          <li>
            <a
              href={SITE.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline text-paper/80 transition-colors hover:text-paper"
            >
              Instagram {SITE.social.instagramHandle}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mono-label mt-14 flex flex-col gap-2 border-t border-paper/15 pt-6 text-paper/50 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {SITE.name}. <T k="footer.rights" /></p>
      <p><T k="footer.tagline2" /> · {SITE.shootingRegion}</p>
    </div>
  </div>
</footer>
