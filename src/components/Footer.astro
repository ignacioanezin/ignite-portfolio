---
import { SITE, NAV_LINKS } from '@/lib/site';
const year = new Date().getFullYear();
---

<!-- DARK — flows out of the dark CTA so the page ends cohesively. -->
<footer class="border-t border-bone/10 bg-ink text-bone">
  <div class="container-rail py-14 md:py-20">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr]">
      <!-- Brand + pitch -->
      <div>
        <p class="font-display text-2xl font-medium tracking-tight text-bone">
          {SITE.name}
        </p>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-bone-dim">
          {SITE.heroStatement}
        </p>
        <p class="mt-4 text-sm text-bone-faint">
          {SITE.baseLocation} · {SITE.shootingRegion}
        </p>
      </div>

      <!-- Nav -->
      <nav aria-label="Footer">
        <p class="eyebrow mb-4 text-bone-faint">Site</p>
        <ul class="space-y-2.5">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="link-underline text-sm text-bone-dim transition-colors hover:text-bone"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <p class="eyebrow mb-4 text-bone-faint">Get in touch</p>
        <ul class="space-y-2.5">
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="link-underline text-sm text-bone-dim transition-colors hover:text-bone"
            >
              {SITE.email}
            </a>
          </li>
          <li>
            <a
              href={SITE.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline text-sm text-bone-dim transition-colors hover:text-bone"
            >
              Instagram {SITE.social.instagramHandle}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col gap-2 border-t border-bone/10 pt-6 text-xs text-bone-faint sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {SITE.name}. All rights reserved.</p>
      <p>Athlete-filmmaker · {SITE.shootingRegion}</p>
    </div>
  </div>
</footer>
