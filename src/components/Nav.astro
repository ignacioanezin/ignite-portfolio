---
import { SITE, NAV_LINKS } from '@/lib/site';
import { ui } from '@/i18n/ui';
import T from '@/components/T.astro';
import LangToggle from '@/components/LangToggle.astro';
import MobileNav from '@/components/react/MobileNav.tsx';

interface Props {
  /** Retained for API compatibility (reel hero). The canvas is light. */
  darkChrome?: boolean;
}
const { darkChrome = false } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

// Bilingual labels for the React mobile menu (rendered as dual spans there).
const navLinks = NAV_LINKS.map((l) => ({
  href: l.href,
  en: ui.en[l.key] ?? l.label,
  es: ui.es[l.key] ?? l.label,
}));
const menuLabels = {
  openEn: ui.en['nav.menu_open'],
  openEs: ui.es['nav.menu_open'],
  closeEn: ui.en['nav.menu_close'],
  closeEs: ui.es['nav.menu_close'],
};
---

<header
  class:list={['fixed inset-x-0 top-0 z-50 text-ink', darkChrome && 'is-dark']}
  data-site-header
>
  <div class="container-rail flex items-center justify-between py-5 md:py-7">
    <!-- Logo (left) — proper noun, never translated. -->
    <a
      href="/"
      class="font-display text-lg font-bold uppercase tracking-tight transition-opacity hover:opacity-70"
      aria-label={`${SITE.name} — home`}
    >
      {SITE.name}
    </a>

    <!-- Right cluster: availability + nav + language (desktop) -->
    <div class="hidden items-center gap-7 md:flex">
      {
        SITE.availability && (
          <span class="mono-label flex items-center gap-2 text-ink-faint">
            <span class="relative flex h-1.5 w-1.5" aria-hidden="true">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-flare opacity-60" />
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-flare" />
            </span>
            <T k="nav.availability" />
          </span>
        )
      }

      <nav aria-label="Primary">
        <ul class="flex items-center gap-6">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                  class:list={[
                    'mono-label transition-colors',
                    isActive(link.href)
                      ? 'text-flare'
                      : 'text-ink hover:text-flare',
                  ]}
                >
                  <T k={link.key} />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <LangToggle darkChrome={darkChrome} />
    </div>

    <!-- Mobile: language toggle + hamburger -->
    <div class="flex items-center gap-4 text-ink md:hidden">
      <LangToggle darkChrome={darkChrome} />
      <MobileNav
        links={navLinks}
        menuLabels={menuLabels}
        currentPath={path}
        client:idle
      />
    </div>
  </div>
</header>
