---
import { SITE, NAV_LINKS } from '@/lib/site';
import { ui } from '@/i18n/ui';
import T from '@/components/T.astro';
import LangToggle from '@/components/LangToggle.astro';
import MobileNav from '@/components/react/MobileNav.tsx';

interface Props {
  /** True when the nav sits over a dark surface (reel-mode hero). */
  darkChrome?: boolean;
}
const { darkChrome = false } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

// Adaptive foreground: ink on the light brand, bone over a dark reel hero.
const fg = darkChrome ? 'text-bone' : 'text-ink';

// Bilingual labels for the React mobile menu (rendered as dual spans there).
const navLinks = NAV_LINKS.map((l) => ({
  href: l.href,
  en: ui.en[l.key] ?? l.label,
  es: ui.es[l.key] ?? l.label,
}));
const menuLabels = {
  openEn: ui.en['nav.menu_open'],
  openEs: ui.es['nav.menu_open'],
  closeEn: ui.en['nav.menu_close'],
  closeEs: ui.es['nav.menu_close'],
};
---

<header
  class:list={['fixed inset-x-0 top-0 z-50', darkChrome && 'is-dark']}
  data-site-header
>
  <div class="container-rail flex items-center justify-between py-5 md:py-7">
    <!-- Logo (left) — proper noun, never translated. -->
    <a
      href="/"
      class:list={[
        'text-base font-medium tracking-tight transition-opacity hover:opacity-70',
        fg,
      ]}
      aria-label={`${SITE.name} — home`}
    >
      {SITE.name}
    </a>

    <!-- Right cluster: availability + nav + language (desktop) -->
    <div class="hidden items-center gap-7 md:flex">
      {
        SITE.availability && (
          <span
            class:list={[
              'flex items-center gap-2 text-xs font-medium',
              darkChrome ? 'text-signal-soft' : 'text-signal',
            ]}
          >
            <span class="relative flex h-1.5 w-1.5" aria-hidden="true">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-current opacity-60" />
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-current" />
            </span>
            <T k="nav.availability" />
          </span>
        )
      }

      <nav aria-label="Primary">
        <ul class="flex items-center gap-7">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                  class:list={[
                    'link-underline text-sm font-medium tracking-wide transition-opacity',
                    fg,
                    isActive(link.href) ? 'opacity-100' : 'opacity-70 hover:opacity-100',
                  ]}
                >
                  <T k={link.key} />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <LangToggle darkChrome={darkChrome} />
    </div>

    <!-- Mobile: language toggle + hamburger -->
    <div class:list={['flex items-center gap-4 md:hidden', fg]}>
      <LangToggle darkChrome={darkChrome} />
      <MobileNav
        links={navLinks}
        menuLabels={menuLabels}
        currentPath={path}
        client:idle
      />
    </div>
  </div>
</header>
