---
import { Image } from 'astro:assets';
import { CATEGORY_META } from '@/content.config';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/T.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Bib index, e.g. "01" (rendered in the start-list gutter). */
  index: string;
  /** Eager-load the still (first couple rows). */
  priority?: boolean;
  class?: string;
}

const { project, index, priority = false, class: className } = Astro.props;
const { data } = project;
const category = CATEGORY_META[data.category];

// "Splits" — optional production stats appended to the meta line (honesty: only
// the ones that exist render).
const splits = [data.lens, data.elevationGain].filter(Boolean) as string[];
---

<a
  href={`/work/${project.id}`}
  class:list={[
    'group relative block border-t-2 border-ink focus-visible:outline-none',
    className,
  ]}
  data-reveal
>
  <div
    class="grid grid-cols-[auto_1fr] items-center gap-x-5 py-7 md:grid-cols-[auto_1fr_auto] md:gap-x-8 md:py-9"
  >
    <!-- Bib index. -->
    <span class="mono text-2xl font-medium text-flare md:text-4xl">{index}</span>

    <!-- Title + meta. -->
    <div class="min-w-0">
      <h3
        class="font-display text-4xl font-bold uppercase leading-[0.92] tracking-tight transition-colors duration-300 group-hover:text-flare sm:text-5xl md:text-6xl"
      >
        {data.title}
      </h3>
      <p class="mono-label mt-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-ink-faint">
        <span class="text-ink"><T k={`cat.${data.category}`} /></span>
        {data.client && <><span aria-hidden="true">·</span><span>{data.client}</span></>}
        <span aria-hidden="true">·</span>
        <span class="tnum">{data.year}</span>
        {
          splits.map((s) => (
            <>
              <span aria-hidden="true" class="text-flare">/</span>
              <span class="tnum">{s}</span>
            </>
          ))
        }
      </p>
    </div>

    <!-- Still peek — slides/fades in on hover (desktop). -->
    <div
      data-img-reveal
      class="relative hidden h-24 w-44 shrink-0 overflow-hidden bg-paper-bright md:block lg:h-28 lg:w-56"
    >
      <Image
        src={data.thumbnail}
        alt={`${data.title} — ${category.label}`}
        widths={[224, 448]}
        sizes="14rem"
        loading={priority ? 'eager' : 'lazy'}
        class="h-full w-full scale-110 object-cover opacity-0 transition-all duration-500 ease-out group-hover:scale-100 group-hover:opacity-100"
      />
      <!-- Flare wipe that clears to reveal the still. -->
      <span
        class="pointer-events-none absolute inset-0 origin-left scale-x-100 bg-flare transition-transform duration-500 ease-out group-hover:scale-x-0"
        aria-hidden="true"
      ></span>
    </div>
  </div>
</a>
