---
import { Image } from 'astro:assets';
import { CATEGORY_META } from '@/content.config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Eager-load the first row of cards (above the fold). */
  priority?: boolean;
  /** Render for a DARK section (Featured Work): full-bleed image, no container,
      outlined pill, bone text. Defaults to the light treatment (Work grid). */
  onDark?: boolean;
  /** Extra classes merged onto the card root (e.g. responsive visibility). */
  class?: string;
}

const { project, priority = false, onDark = false, class: className } = Astro.props;
const { data } = project;
const category = CATEGORY_META[data.category];

const title = onDark ? 'text-bone' : 'text-ink';
const excerpt = onDark ? 'text-bone-dim' : 'text-ink-dim';
const meta = onDark ? 'text-bone-faint' : 'text-ink-faint';
const divider = onDark ? 'border-bone/12' : 'border-line';
---

<a
  href={`/work/${project.id}`}
  class:list={['group block focus-visible:outline-none', className]}
  data-reveal
>
  <!-- Aspect box reserved up-front → zero layout shift. On dark the image IS
       the card (no container/ring); photography creates the depth. -->
  <div
    class:list={[
      'relative aspect-[16/9] overflow-hidden rounded-md',
      onDark
        ? 'bg-ink'
        : 'bg-bone-raise ring-1 ring-line transition-[box-shadow] duration-500 group-hover:ring-ink/30',
    ]}
  >
    <Image
      src={data.thumbnail}
      alt={`${data.title} — ${category.label}`}
      widths={[480, 800, 1200, 1600]}
      sizes="(min-width: 768px) 50vw, 100vw"
      loading={priority ? 'eager' : 'lazy'}
      class="kb h-full w-full object-cover"
    />

    {
      data.previewClip && (
        <video
          class="hover-clip absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500"
          src={data.previewClip}
          muted
          loop
          playsinline
          preload="none"
          aria-hidden="true"
        />
      )
    }

    <!-- Category — outlined/transparent pill on dark, ink fill on light. -->
    <span
      class:list={[
        'absolute left-4 top-4 rounded-full px-3 py-1 text-[0.7rem] font-medium uppercase tracking-wider backdrop-blur-sm',
        onDark
          ? 'border border-bone/40 text-bone'
          : 'bg-ink/85 text-bone',
      ]}
    >
      {category.label}
    </span>
  </div>

  <div class:list={['mt-5 border-t pt-4', divider]}>
    <div class="flex items-baseline justify-between gap-4">
      <h3
        class:list={[
          'font-display text-xl font-medium tracking-tight underline-offset-[6px] decoration-1 group-hover:underline md:text-2xl',
          title,
        ]}
      >
        {data.title}
      </h3>
      <span class:list={['shrink-0 text-sm', meta]}>{data.year}</span>
    </div>
    <p class:list={['mt-1.5 text-sm leading-relaxed', excerpt]}>{data.excerpt}</p>
    {
      data.client && (
        <p class:list={['mt-2 text-xs uppercase tracking-wider', meta]}>
          {data.client} · {data.location}
        </p>
      )
    }
  </div>
</a>

<style>
  /* Ken-Burns: a slow push-in on hover (the default hover-preview when there's
     no preview clip). Disabled under reduced motion. */
  .kb {
    transform: scale(1);
    transition: transform 1.6s var(--ease-cinematic);
  }
  .group:hover .kb {
    transform: scale(1.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .kb {
      transition: none;
    }
    .group:hover .kb {
      transform: none;
    }
    .hover-clip {
      display: none;
    }
  }
</style>

<script>
  // Hover-to-preview for cards that have a previewClip: load + play the muted
  // loop on hover (desktop / pointer:fine), pause + reset on leave. Touch
  // devices never fire hover, so they keep the static thumbnail. Vanilla — no
  // React (kept for the grid filter / lightbox / nav / hero per brief).
  function initHoverClips() {
    const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!fine || reduce) return;

    document.querySelectorAll<HTMLVideoElement>('.hover-clip').forEach((video) => {
      const card = video.closest('a');
      if (!card || card.dataset.hoverBound) return;
      card.dataset.hoverBound = 'true';
      card.addEventListener('mouseenter', () => {
        if (!video.src) video.src = video.dataset.src || video.src;
        video.play().then(() => (video.style.opacity = '1')).catch(() => {});
      });
      card.addEventListener('mouseleave', () => {
        video.style.opacity = '0';
        video.pause();
      });
    });
  }
  initHoverClips();
  document.addEventListener('astro:page-load', initHoverClips);
</script>
